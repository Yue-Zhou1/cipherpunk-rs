{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DistanceMetric": {
      "enum": [
        "cosine"
      ],
      "type": "string"
    },
    "Evidence": {
      "properties": {
        "excerpt": {
          "type": "string"
        },
        "section_title": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "excerpt"
      ],
      "type": "object"
    },
    "ExtractionMetadata": {
      "properties": {
        "confidence": {
          "type": "string"
        },
        "embedding_text_version": {
          "type": "string"
        },
        "review_status": {
          "type": "string"
        }
      },
      "required": [
        "confidence",
        "embedding_text_version",
        "review_status"
      ],
      "type": "object"
    },
    "Invariants": {
      "properties": {
        "kani_hint": {
          "type": [
            "string",
            "null"
          ]
        },
        "natural_language": {
          "type": "string"
        }
      },
      "required": [
        "natural_language"
      ],
      "type": "object"
    },
    "Remediation": {
      "properties": {
        "code_pattern": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "code_pattern",
        "description"
      ],
      "type": "object"
    },
    "ResolvedEmbeddingConfig": {
      "properties": {
        "dimensions": {
          "format": "uint32",
          "minimum": 0.0,
          "type": "integer"
        },
        "distance_metric": {
          "$ref": "#/definitions/DistanceMetric"
        },
        "embedding_text_version": {
          "type": "string"
        },
        "l2_normalized": {
          "type": "boolean"
        },
        "model": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        }
      },
      "required": [
        "dimensions",
        "distance_metric",
        "embedding_text_version",
        "l2_normalized",
        "model",
        "provider"
      ],
      "type": "object"
    },
    "SignatureSource": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "page_range": {
          "items": {
            "format": "uint32",
            "minimum": 0.0,
            "type": "integer"
          },
          "maxItems": 2,
          "minItems": 2,
          "type": "array"
        },
        "pdf_path": {
          "type": "string"
        },
        "report": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "page_range",
        "pdf_path",
        "report"
      ],
      "type": "object"
    },
    "VulnerabilityDetails": {
      "properties": {
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "root_cause": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "vulnerable_pattern": {
          "type": "string"
        }
      },
      "required": [
        "category",
        "description",
        "root_cause",
        "severity",
        "title",
        "vulnerable_pattern"
      ],
      "type": "object"
    },
    "VulnerabilitySignature": {
      "properties": {
        "embedding_text": {
          "type": "string"
        },
        "evidence": {
          "$ref": "#/definitions/Evidence"
        },
        "extraction": {
          "$ref": "#/definitions/ExtractionMetadata"
        },
        "id": {
          "type": "string"
        },
        "invariants": {
          "$ref": "#/definitions/Invariants"
        },
        "remediation": {
          "$ref": "#/definitions/Remediation"
        },
        "source": {
          "$ref": "#/definitions/SignatureSource"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "vulnerability": {
          "$ref": "#/definitions/VulnerabilityDetails"
        }
      },
      "required": [
        "embedding_text",
        "evidence",
        "extraction",
        "id",
        "invariants",
        "remediation",
        "source",
        "tags",
        "vulnerability"
      ],
      "type": "object"
    }
  },
  "properties": {
    "embedding": {
      "$ref": "#/definitions/ResolvedEmbeddingConfig"
    },
    "generated_at": {
      "type": "string"
    },
    "schema_version": {
      "format": "uint32",
      "minimum": 0.0,
      "type": "integer"
    },
    "signatures": {
      "items": {
        "$ref": "#/definitions/VulnerabilitySignature"
      },
      "type": "array"
    }
  },
  "required": [
    "embedding",
    "generated_at",
    "schema_version",
    "signatures"
  ],
  "title": "ArtifactMetadata",
  "type": "object"
}